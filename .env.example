# Copy to .env, fill in, then `set -a && source .env && set +a` before running.

# TechniDox API host. Dev default shown; production is https://api.technidox.dev
TECHNIDOX_API_BASE_URL=https://dev-api.technidox.dev

# Firebase web API key for the project TechniDox trusts (technidox-prod).
# TechniDox verifies Firebase ID tokens server-side (same model as DartStream):
# the client authenticates against Firebase Identity Toolkit, gets an ID token,
# and sends it as `Authorization: Bearer <idToken>`. Without this key the
# unauthenticated /health check still runs and authed steps are SKIPPED.
FIREBASE_API_KEY=

# Test user for the authed steps. On first run the user won't exist, so the
# harness auto-signs them up. Real values go ONLY in your gitignored .env.
TEST_EMAIL=you@example.com
TEST_PASSWORD=change-me

# Tenant scoping sent to the API (x-tenant-id). Signup also returns a tenant;
# set this only to override.
TECHNIDOX_TENANT_ID=default
